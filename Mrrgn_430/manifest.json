{
  "name": "Morrigan",
  "version": "0.3",
  "manifest_version": 3,
  "description": "Morrigan is a Chrome AI Built-in extension for safer browsing — powered by the Prompt API and Gemini Nano for on-device scam and phishing detection.",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["sidePanel"],
  "minimum_chrome_version": "138",
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "action": {
    "default_icon": {
      "16": "images/icon16.png",
      "32": "images/icon32.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    },
    "default_title": "Open Morrigan"
  },
  "web_accessible_resources": [
    {
      "resources": ["data/phishing_patterns.json"],
      "matches": ["<all_urls>"]
    }
  ]
}